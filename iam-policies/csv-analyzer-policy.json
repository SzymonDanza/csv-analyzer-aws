{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "ReadFromUploadsBucket",
            "Effect": "Allow",
            "Action": ["s3:GetObject"],
            "Resource": "arn:aws:s3:::UPLOAD_BUCKET_NAME_PLACEHOLDER/*"
        },
        {
            "Sid": "WriteToReportsBucket",
            "Effect": "Allow",
            "Action": ["s3:PutObject"],
            "Resource": "arn:aws:s3:::REPORTS_BUCKET_NAME_PLACEHOLDER/*"
        },
        {
            "Sid": "DynamoDBWriteAccess",
            "Effect": "Allow",
            "Action": [
                "dynamodb:PutItem",
                "dynamodb:GetItem",
                "dynamodb:Query",
                "dynamodb:Scan"
            ],
            "Resource": "arn:aws:dynamodb:eu-central-1:*:table/csv-analyses"
        }
    ]
}
